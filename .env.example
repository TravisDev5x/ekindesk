APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Headers de seguridad (X-Content-Type-Options, X-Frame-Options, Referrer-Policy). Leído vía config/security.php.
SECURITY_HEADERS_ENABLED=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
REPORT_AUDIT_ENABLED=true
REPORT_AUDIT_CHANNEL=reports
REPORT_LOG_LEVEL=info
REPORT_LOG_DAYS=14
TICKET_AUDIT_ENABLED=false
TICKET_AUDIT_CHANNEL=audit
AUDIT_LOG_LEVEL=info
AUDIT_LOG_DAYS=30

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Dominios desde los que la SPA envía cookies de sesión (Sanctum). En producción añade tu dominio.
# Para probar desde otro dispositivo en la red: añade tu IP (ej. 192.168.1.100 y 192.168.1.100:8000).
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,helpdeskreact.test

# -------------------------------------------------------------------------
# Prueba en red local (otro dispositivo en la misma WiFi/LAN)
# -------------------------------------------------------------------------
# Descomenta y ajusta cuando quieras abrir la app desde móvil/tablet/otra PC.
# 1) Obtén tu IP (en PowerShell: ipconfig → Dirección IPv4).
# 2) Sustituye 192.168.1.100 por tu IP real.

# APP_URL=http://192.168.1.100:8000
# SESSION_DOMAIN=null
# SANCTUM_STATEFUL_DOMAINS=192.168.1.100,192.168.1.100:8000,localhost,127.0.0.1

# URL del servidor de Vite que Laravel inyecta en el HTML. Evita CORS con [::]:5173.
# VITE_DEV_SERVER_HOST=192.168.1.100

# Host para HMR al ejecutar npm run dev (ej. en PowerShell: $env:VITE_HMR_HOST="192.168.1.100"; npm run dev).
# VITE_HMR_HOST=192.168.1.100

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
