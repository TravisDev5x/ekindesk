APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Headers de seguridad (X-Content-Type-Options, X-Frame-Options, Referrer-Policy). Leído vía config/security.php.
SECURITY_HEADERS_ENABLED=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
REPORT_AUDIT_ENABLED=true
REPORT_AUDIT_CHANNEL=reports
REPORT_LOG_LEVEL=info
REPORT_LOG_DAYS=14
TICKET_AUDIT_ENABLED=false
TICKET_AUDIT_CHANNEL=audit
AUDIT_LOG_LEVEL=info
AUDIT_LOG_DAYS=30

# sqlite (desarrollo rápido) | mysql | pgsql (recomendado staging/prod multi-tenant)
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# PostgreSQL local (Laragon): scripts/local-pgsql-init.sql → base tikara_local
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=tikara_local
# DB_USERNAME=tikara
# DB_PASSWORD=secret
# TENANCY_PGSQL_RLS=true

# --- Multi-tenant / portales (docs/CLIENT_PORTAL.md, docs/SANCTUM_TENANCY.md) ---
# Portal: https://{portal_slug}.{TENANCY_BASE_DOMAIN}/login
# TENANCY_BASE_DOMAIN=tikara.test
# TENANCY_PORTAL_SCHEME=http
# TENANCY_STRICT_CLIENT_PORTAL=true
# TENANCY_ENFORCE_SUBDOMAIN=true
# Catálogos: false = plataforma + operador MSP (default). true = filas por client_id en portal.
# TENANCY_CATALOG_PER_CLIENT=false
# RLS PostgreSQL (solo pgsql; usuario BD no superuser): docs/DATABASE_TENANCY.md
# TENANCY_PGSQL_RLS=false
# Consola raíz legacy: admin manage_all sin is_operator ve todos los clientes (solo local/staging)
# TENANCY_LEGACY_MSP_WIDE_ACCESS=true

# Laragon: hosts 127.0.0.1 tikara.test + cliente-a.tikara.test
# SESSION_DOMAIN=.tikara.test
# SANCTUM_STATEFUL_DOMAINS=tikara.test,cliente-a.tikara.test,localhost,127.0.0.1

# Google OAuth (login + aceptar invitación). Consola: https://console.cloud.google.com/
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://tikara.test/auth/google/callback

# PostgreSQL (ver docs/DATABASE_TENANCY.md)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=tikara
# DB_USERNAME=tikara
# DB_PASSWORD=
# DB_CHARSET=utf8
# DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SAME_SITE=lax        # "lax" es el default — funciona con Inertia same-domain
# SESSION_SECURE_COOKIE=true   # Activar en producción HTTPS

# Dominios desde los que la SPA envía cookies (Sanctum). Sin https:// ni rutas.
# Admite Str::is() de Laravel: *.tikara.mx coincide con cualquier subdominio.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5174,localhost:8000,localhost:8001,127.0.0.1

# CORS — orígenes cross-origin permitidos con credenciales (cookies de sesión).
# Vacío = solo same-origin. Correcto para Inertia.js donde API y frontend comparten dominio.
# Azure prod: CORS_ALLOWED_ORIGINS=https://tikara.mx
# Portales dinámicos: CORS_ALLOWED_ORIGINS_PATTERNS=^https://[a-z0-9-]+\.tikara\.com$
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGINS_PATTERNS=
CORS_SUPPORTS_CREDENTIALS=true

# -------------------------------------------------------------------------
# Prueba en red local (otro dispositivo en la misma WiFi/LAN)
# -------------------------------------------------------------------------
# Descomenta y ajusta cuando quieras abrir la app desde móvil/tablet/otra PC.
# 1) Obtén tu IP (en PowerShell: ipconfig → Dirección IPv4).
# 2) Sustituye 192.168.1.100 por tu IP real.

# APP_URL=http://192.168.1.100:8000
# SESSION_DOMAIN=null
# SANCTUM_STATEFUL_DOMAINS=192.168.1.100,192.168.1.100:8000,localhost,127.0.0.1

# URL del servidor de Vite que Laravel inyecta en el HTML. Evita CORS con [::]:5173.
# VITE_DEV_SERVER_HOST=192.168.1.100

# Host para HMR al ejecutar npm run dev (ej. en PowerShell: $env:VITE_HMR_HOST="192.168.1.100"; npm run dev).
# VITE_HMR_HOST=192.168.1.100

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Firma HMAC del webhook INBOUND de Mailgun (InboundEmailService). Sin esta key,
# en cualquier entorno que no sea local/testing el webhook rechaza todo (falla
# cerrado), no lo contrario.
MAILGUN_WEBHOOK_SIGNING_KEY=

# Credenciales OUTBOUND (correo transaccional) — distintas de la key de arriba.
# Ver checklist DNS (SPF/DKIM/DMARC) en docs/MAILGUN_OUTBOUND.md antes de usar
# en producción.
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net

# Sin credenciales reales de Mailgun configuradas arriba, cambia esto a "log"
# para desarrollo local (los correos se escriben en storage/logs en vez de
# intentar enviarse).
MAIL_MAILER=mailgun
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="soporte@tikara.mx"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
